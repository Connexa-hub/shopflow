# Copy to .env and fill in real values. Never commit .env.
SERVICE_NAME=sales-service
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

DATABASE_URL=postgresql+asyncpg://shopflow:devpassword@localhost:5432/shopflow_sales
REDIS_URL=redis://localhost:6379/0

# MUST match auth-service's JWT_SECRET_KEY exactly — sales-service
# verifies tokens locally AND forwards them to inventory-service, both
# using this shared secret. See app/core/security.py and
# app/core/inventory_client.py.
JWT_SECRET_KEY=changeme-generate-a-real-32-byte-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO

# Base URL for inventory-service. Inside docker-compose this is the
# service name; for local dev outside Docker use the mapped host port.
INVENTORY_SERVICE_URL=http://inventory-service:8000
INVENTORY_SERVICE_TIMEOUT_SECONDS=10.0
