# Copy to .env and fill in real values. Never commit .env.
SERVICE_NAME=payment-service
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

DATABASE_URL=postgresql+asyncpg://shopflow:devpassword@localhost:5432/shopflow_payment
REDIS_URL=redis://localhost:6379/0

# MUST match every other service's JWT_SECRET_KEY exactly — this service
# verifies tokens locally using this shared secret. See docs/PHASES.md.
JWT_SECRET_KEY=changeme-generate-a-real-32-byte-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO

# Public URL this service is reachable at — used to build each provider's
# callback/redirect URL. Must be reachable by the CUSTOMER'S BROWSER, not
# just internally, since that's who gets redirected there after checkout.
PUBLIC_BASE_URL=http://localhost:8004

# Provider credentials — leave a provider's keys blank to disable it
# entirely (payment-service only registers providers with complete
# credentials; see app/core/dependencies.py). Get these from each
# provider's dashboard; never commit real keys.
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co

FLUTTERWAVE_SECRET_KEY=
# The "secret hash" configured in the Flutterwave dashboard for webhook
# verification — distinct from the API secret key above.
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://api.monnify.com
