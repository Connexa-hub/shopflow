# Copy to .env and fill in real values. Never commit .env.
SERVICE_NAME=inventory-service
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

DATABASE_URL=postgresql+asyncpg://shopflow:devpassword@localhost:5432/shopflow_inventory
REDIS_URL=redis://localhost:6379/0

# MUST match auth-service's JWT_SECRET_KEY exactly — inventory-service
# verifies tokens locally using this shared secret rather than calling
# auth-service on every request. See app/core/security.py.
JWT_SECRET_KEY=changeme-generate-a-real-32-byte-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO

# If true, stock movements can drive a product's quantity below zero
# instead of being rejected. Off by default — see core/config.py.
ALLOW_NEGATIVE_STOCK=false
